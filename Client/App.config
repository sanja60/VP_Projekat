<?xml version="1.0" encoding="utf-8"?>
<configuration>
	<system.serviceModel>
		<client>
			<endpoint address="net.tcp://localhost:8088/VetrogeneratorService" binding="netTcpBinding" bindingConfiguration="ClientTcp" contract="Common.Contracts.IVetrogeneratorService" name="VetrogeneratorEndpoint"/>
		</client>

		<bindings>
			<netTcpBinding>
				<binding name="ClientTcp" maxReceivedMessageSize="10485760">
					<security mode="None"/>
				</binding>
			</netTcpBinding>
		</bindings>
	</system.serviceModel>
<startup><supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8"/></startup></configuration>
